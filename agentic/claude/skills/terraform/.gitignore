# Terraform working directory
.terraform/
.terraform.tfstate.lock.info

# Plan files (may contain sensitive computed values)
*.tfplan
plan-*.tfplan

# Audit output (regenerated by `task audit`)
audit-results/

# State files — should never be local, but belt-and-braces
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Crash logs
crash.log
crash.*.log

# Local override files (per-developer)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration with credentials
.terraformrc
terraform.rc

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.swp

# devbox local overrides
.devbox/

# direnv
.envrc.local

# NOTE: .terraform.lock.hcl IS committed to git — it pins provider versions.
# NOTE: backend-*.hcl ARE committed to git — they're partial config, no secrets.
# NOTE: vars/*.hcl ARE committed to git — they hold non-secret config.
# Anything secret-shaped goes through Vault or AWS Secrets Manager (see references/secrets.md).
